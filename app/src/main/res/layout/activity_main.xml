<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F5FA">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#CF6711"
        android:minHeight="?attr/actionBarSize"
        android:theme="?attr/actionBarTheme"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gold Zakat Calculator"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="#2E2E2E"
        android:fontFamily="sans-serif-medium"
        android:layout_marginTop="35dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <EditText
        android:id="@+id/etWeight"
        android:layout_width="320dp"
        android:layout_height="55dp"
        android:hint="Gold Weight (gram)"
        android:textColor="#333333"
        android:textColorHint="#9E9E9E"
        android:backgroundTint="#7E57C2"
        android:textSize="16sp"
        android:padding="12dp"
        android:inputType="numberDecimal"
        android:layout_marginTop="35dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Spinner
        android:id="@+id/spinnerType"
        android:layout_width="320dp"
        android:layout_height="55dp"
        android:backgroundTint="#7E57C2"
        android:layout_marginTop="18dp"
        app:layout_constraintTop_toBottomOf="@id/etWeight"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <EditText
        android:id="@+id/etValue"
        android:layout_width="320dp"
        android:layout_height="55dp"
        android:hint="Gold Value per Gram"
        android:textColor="#333333"
        android:textColorHint="#9E9E9E"
        android:backgroundTint="#7E57C2"
        android:textSize="16sp"
        android:padding="12dp"
        android:inputType="numberDecimal"
        android:layout_marginTop="18dp"
        app:layout_constraintTop_toBottomOf="@id/spinnerType"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnCalculate"
        android:layout_width="320dp"
        android:layout_height="55dp"
        android:text="Calculate"
        android:textStyle="bold"
        android:textSize="17sp"
        android:textColor="@android:color/white"
        android:backgroundTint="#F2A23A"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toBottomOf="@id/etValue"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:id="@+id/resultCard"
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp"
        android:layout_marginTop="35dp"
        app:layout_constraintTop_toBottomOf="@id/btnCalculate"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvTotalGold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total Gold Value:"
            android:textSize="19sp"
            android:textStyle="bold"
            android:textColor="#424242"/>

        <TextView
            android:id="@+id/tvZakatPayable"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Zakat Payable:"
            android:textSize="19sp"
            android:textStyle="bold"
            android:textColor="#424242"
            android:layout_marginTop="14dp"/>

        <TextView
            android:id="@+id/tvTotalZakat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total Zakat:"
            android:textSize="19sp"
            android:textStyle="bold"
            android:textColor="#424242"
            android:layout_marginTop="14dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>